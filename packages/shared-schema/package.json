{
  "name": "@ppt-pilot/shared-schema",
  "version": "0.0.0",
  "private": true,
  "description": "Canonical shared schema contract for PPTPilot structured presentation data.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "fixtures",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "validate:fixtures": "pnpm run build && node scripts/validate-fixtures.mjs",
    "validate": "pnpm run validate:fixtures"
  }
}
