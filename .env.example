# PPTPilot 运行时配置模板
# 复制为 .env 并填入真实值：`cp .env.example .env`
# .env 已被 gitignore，切勿提交密钥。仓库根 .env 是所有服务共用的唯一配置源。

# LLM provider：mock（默认，离线/CI）| openrouter（真实调用）
LLM_PROVIDER=mock

# --- OpenRouter（LLM_PROVIDER=openrouter 时必填 API key）---
OPENROUTER_API_KEY=
# 模型 id；留空则用 "auto"（openrouter/auto 自动选路）
OPENROUTER_MODEL=openai/gpt-4o-mini
# 可选：自定义网关与超时（秒）
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_TIMEOUT=30
